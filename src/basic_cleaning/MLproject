name: basic_cleaning
conda_env: conda.yml

entry_points:
  main:
    parameters:

      input_artifact:
        description: this is the input artifact name
        type: str

      output_artifact:
        description: this is the output artifact name
        type: str

      output_type:
        description: this is the output artifact type
        type: str

      output_description:
        description: this is the output artifact description
        type: str

      min_price:
        description: this is the minimum price
        type: float

      max_price:
        description: this is the maximum price
        type: float


    command: >-
        python run.py  --input_artifact {input_artifact}  --output_artifact {output_artifact}  --output_type {output_type}  --output_description {output_description}  --min_price {min_price}  --max_price {max_price} 
